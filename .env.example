# Copy to .env and fill in. .env is gitignored.

# Required by `bounty-agent llm-classify` and by any code path that calls
# the optional LLM post-processor. Off by default; even if this is set,
# the LLM only runs when config.llm.enabled = true.
ANTHROPIC_API_KEY=

# Optional. Override any config field via BOUNTY_AGENT_<SECTION>__<FIELD>.
# Example: BOUNTY_AGENT_AGENT__MAX_REQUESTS_PER_MINUTE=10
# Environment values win over the YAML.
# BOUNTY_AGENT_LLM__ENABLED=true
# BOUNTY_AGENT_SCOPE__ALLOWLIST=["api.example.com","staging.example.com"]

# Optional. Point at an alternate config file (default is ./config/default.yaml).
# BOUNTY_AGENT_CONFIG=./juice.yaml
